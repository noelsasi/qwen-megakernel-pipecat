# Copy to .env and fill in values on the Vast.ai server
# Do NOT commit .env to git

# Required: restrict CORS to your Vercel deployment
ALLOWED_ORIGIN=https://your-app.vercel.app

# Required: HuggingFace token for gated model access
HF_TOKEN=hf_...

# LLM provider (pick one)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# STT (optional — Deepgram is lower latency than Whisper)
# DEEPGRAM_API_KEY=...

# TTS backend: "hf" (default) or "megakernel" (Phase D)
TTS_BACKEND=hf
